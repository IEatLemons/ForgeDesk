{
  "name": "forgedesk",
  "version": "1.0.8",
  "description": "Local-first project management console for repositories, environments, deployments, and AI reports.",
  "license": "MIT",
  "main": "out/main/index.js",
  "bin": {
    "forgedesk": "out/main/cli.js"
  },
  "type": "module",
  "scripts": {
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "build:menu-bar-helper": "node scripts/build-menu-bar-helper.mjs",
    "dev": "node scripts/build-menu-bar-helper.mjs && node scripts/rebuild-native.mjs && electron-vite dev",
    "build": "node scripts/build-menu-bar-helper.mjs && node scripts/rebuild-native.mjs && tsc --noEmit && electron-vite build",
    "package:mac": "node scripts/build-menu-bar-helper.mjs && node scripts/rebuild-native.mjs && tsc --noEmit && electron-vite build && electron-builder --mac --publish never",
    "publish:mac": "node scripts/publish-mac.mjs",
    "package:mac:legacy": "node scripts/package-mac.mjs",
    "preview": "node scripts/build-menu-bar-helper.mjs && node scripts/rebuild-native.mjs && electron-vite preview",
    "test": "node scripts/run-tests.mjs",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^5.22.5",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "app.forgedesk.desktop",
    "productName": "ForgeDesk",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/.cache{,/**/*}",
      "!**/node_modules/.ignored_*{,/**/*}",
      "!**/node_modules/.pnpm/electron@*/**/*",
      "!**/node_modules/.vite{,/**/*}",
      "!**/node_modules/electron{,/**/*}",
      "!**/node_modules/electron-builder{,/**/*}",
      "!**/node_modules/electron-vite{,/**/*}",
      "!**/node_modules/typescript{,/**/*}",
      "!**/node_modules/vite{,/**/*}"
    ],
    "extraResources": [
      {
        "from": "resources/forgedesk.png",
        "to": "forgedesk.png"
      },
      {
        "from": "resources/MenuBarHelper",
        "to": "MenuBarHelper"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*"
    ],
    "npmRebuild": false,
    "afterSign": "scripts/after-sign.cjs",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/forgedesk.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "IEatLemons",
        "repo": "ForgeDesk",
        "releaseType": "release"
      }
    ]
  }
}
